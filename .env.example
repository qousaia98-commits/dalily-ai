# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role — server-only, never expose to the client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Optional: overrides for LLM-assisted search problem classification and
# voice transcription (both fall back to OPENAI_API_KEY / gpt-4o-mini).
# SEARCH_LLM_API_KEY=
# SEARCH_LLM_API_URL=
# SEARCH_LLM_MODEL=gpt-4o-mini

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Closed beta: set to "false" only for public launch (enables robots indexing)
DALILY_CLOSED_BETA=true

# Payment (manual bank transfer) — REQUIRED for paid plan upgrades in production.
# Leave empty in local/dev to fail closed (upgrade UI blocks instead of showing fake IBAN).
PAYMENT_PROVIDER=manual
PAYMENT_RECEIVER=
PAYMENT_ACCOUNT=
PAYMENT_IBAN=
PAYMENT_SWIFT=
PAYMENT_BANK_NAME=

# Optional: Resend confirmation emails after payment approval
# RESEND_API_KEY=
# EMAIL_FROM=Dalily <noreply@dalily.app>
